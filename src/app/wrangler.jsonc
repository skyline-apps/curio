{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "curio",
  "main": "api/index.ts",
  "compatibility_date": "2025-04-03",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "keep_vars": true,
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
  },
  "env": {
    "staging": {
      "observability": {
        "enabled": true,
        "head_sampling_rate": 1,
      },
      "vars": {
        "ENVIRONMENT": "staging"
      },
      "queues": {
        "producers": [
          {
            "queue": "items-fetcher-staging",
            "binding": "ITEMS_FETCHER_QUEUE"
          }
        ]
      },
      "r2_buckets": [
        {
          "binding": "ITEMS_BUCKET",
          "bucket_name": "curio-items-staging"
        },
        {
          "binding": "IMPORT_BUCKET",
          "bucket_name": "curio-imports-staging"
        }
      ]
    },
    "prod": {
      "observability": {
        "enabled": true,
        "head_sampling_rate": 1,
      },
      "vars": {
        "ENVIRONMENT": "prod"
      },
      "queues": {
        "producers": [
          {
            "queue": "items-fetcher-prod",
            "binding": "ITEMS_FETCHER_QUEUE"
          }
        ]
      },
      "r2_buckets": [
        {
          "binding": "ITEMS_BUCKET",
          "bucket_name": "curio-items-prod"
        },
        {
          "binding": "IMPORT_BUCKET",
          "bucket_name": "curio-imports-prod"
        }
      ]
    }
    // Uncomment the below to run import locally
    // },
    // "queues": {
    //   "producers": [
    //     {
    //       "queue": "items-fetcher",
    //       "binding": "ITEMS_FETCHER_QUEUE"
    //     }
    //   ],
    //   "consumers": [
    //     {
    //       "queue": "items-fetcher",
    //       "max_batch_size": 1
    //     }
    //   ]
  }
}